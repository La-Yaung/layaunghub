# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Local dev + the seed script read these; on Vercel set the same keys in
# Project → Settings → Environment Variables.

# --- Supabase (Project → Settings → API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key           # used by the site to READ posts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # used by the webhook/seed to WRITE (keep secret!)

# --- Telegram (from @BotFather) ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_WEBHOOK_SECRET=make-up-a-long-random-string   # you choose this; used to verify webhook calls
TELEGRAM_ALLOWED_CHAT_ID=-1001234567890                 # your channel's id (optional but recommended)
