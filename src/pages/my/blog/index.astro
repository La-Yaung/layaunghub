---
// Burmese blog index (/my/blog/) — server-rendered from Supabase, newest first.
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Background from '../../../components/Background.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import Icon from '../../../components/Icon.astro';
import { blog } from '../../../data/blog.my';
import { getPosts } from '../../../lib/blog-db';

const base = '/my/';
const posts = await getPosts();
---
<BaseLayout
  path="/my/blog/"
  title={blog.meta.title}
  description={blog.meta.description}
  noAlternates
>
  <div class="relative overflow-hidden bg-app">
    <Background />
    <div class="relative z-[2]">
      <Nav base={base} />

      <main class="max-w-[880px] mx-auto px-[clamp(20px,5vw,72px)] pt-[clamp(24px,4vw,44px)] pb-[clamp(56px,7vw,88px)]">
        <header class="mb-[clamp(28px,4vw,44px)]">
          <div class="inline-flex items-center gap-2 mb-5 rounded-full bg-surface-brand/[0.08] border border-border-interactive/25 px-3.5 py-[7px]">
            <Icon name="note" size={16} class="text-content-brand" />
            <span class="font-mono text-11-5 tracking-caps uppercase text-content-brand">{blog.eyebrow}</span>
          </div>
          <h1 class="font-display text-display-sm font-bold leading-110 text-content-primary">{blog.heading}</h1>
          <p class="text-17 text-content-secondary mt-5 leading-160 max-w-[620px]">{blog.intro}</p>
        </header>

        {posts.length === 0 ? (
          <p class="text-16 text-content-tertiary py-10">{blog.empty}</p>
        ) : (
          <div class="flex flex-col gap-4">
            {posts.map((post) => (
              <a
                href={`${base}blog/${post.slug}/`}
                class="group block rounded-[20px] bg-surface-tertiary border border-border-subtle p-[clamp(20px,3vw,28px)] transition duration-200 hover:-translate-y-1 hover:border-border-interactive/40"
              >
                <div class="flex items-center gap-3 flex-wrap mb-3">
                  <time datetime={post.date} class="text-12-5 text-content-tertiary">{post.dateLabel}</time>
                  {post.tags.map((t) => (
                    <span class="text-11 font-mono tracking-caps uppercase text-content-brand bg-surface-brand/[0.08] border border-border-interactive/25 rounded-full px-2.5 py-[3px]">{t}</span>
                  ))}
                </div>
                <h2 class="font-display text-22 font-bold leading-130 text-content-primary group-hover:text-content-brand transition-colors">{post.title}</h2>
                <p class="text-16 text-content-secondary mt-2.5 leading-160">{post.excerpt}</p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-14-5 font-semibold text-content-brand">{blog.readMore}<Icon name="compass" size={16} class="text-content-brand" /></span>
              </a>
            ))}
          </div>
        )}
      </main>

      <Footer base={base} />
    </div>
  </div>
</BaseLayout>
