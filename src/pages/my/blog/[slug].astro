---
// Burmese blog post — server-rendered from Supabase at request time, so a new
// post (e.g. ingested from Telegram) is live instantly with no rebuild.
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPost from '../../../components/BlogPost.astro';
import { blog } from '../../../data/blog.my';
import { getPostBySlug, getPosts } from '../../../lib/blog-db';

const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : null;
if (!post) return new Response('Not found', { status: 404 });

const related = (await getPosts()).filter((p) => p.slug !== post.slug).slice(0, 2);
const origin = 'https://layaunghub.com';
---
<BaseLayout
  path={`/my/blog/${post.slug}/`}
  title={`${post.title} | La Yaung Hub`}
  description={post.excerpt}
  image={post.ogUrl ?? '/og-image.png'}
  imageAlt={post.title}
  articleHeadline={post.title}
  articleType="BlogPosting"
  articleTags={post.tags}
  datePublished={post.date}
  breadcrumb={post.title}
  breadcrumbParent={{ name: blog.eyebrow, url: `${origin}/my/blog/` }}
  noAlternates
>
  <BlogPost post={post} related={related} />
</BaseLayout>
