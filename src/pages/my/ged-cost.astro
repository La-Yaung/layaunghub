---
// "How much does the GED cost in Myanmar?" — Burmese (my). English at /ged-cost/.
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuidePage from '../../components/GuidePage.astro';
import { getGuides } from '../../data/i18n';

const slug = 'ged-cost' as const;
const guide = getGuides(Astro.currentLocale)[slug];
---
<BaseLayout
  path="/my/ged-cost/"
  title={guide.meta.title}
  description={guide.meta.description}
  faqItems={guide.faqs}
  articleHeadline={guide.h1}
  breadcrumb={guide.navLabel}
>
  <GuidePage slug={slug} />
</BaseLayout>
