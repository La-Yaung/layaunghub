---
// Free GED readiness quiz — English (en). Burmese at /my/ged-readiness-quiz/.
import BaseLayout from '../layouts/BaseLayout.astro';
import QuizPage from '../components/QuizPage.astro';
import { getQuiz } from '../data/i18n';

const q = getQuiz(Astro.currentLocale);
---
<BaseLayout
  path="/ged-readiness-quiz/"
  title={q.meta.title}
  description={q.meta.description}
  faqItems={q.faqs}
>
  <QuizPage />
</BaseLayout>
