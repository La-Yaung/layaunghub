---
import { freePlan, proPlan } from '../data/content';
---
<section id="pricing" class="ly-reveal max-w-[1100px] mx-auto pt-[clamp(40px,6vw,56px)] px-[clamp(20px,5vw,72px)] pb-[clamp(70px,9vw,110px)]">
  <div class="text-center max-w-[640px] mx-auto mb-[52px]">
    <div class="font-mono text-12 tracking-caps-xl uppercase text-content-brand mb-[18px]">05 / Pricing</div>
    <h2 class="font-display text-display-md font-bold leading-106">Start free. <span class="text-gold">Always.</span></h2>
    <p class="text-17 text-content-secondary mt-[18px] leading-160">The first lesson of every topic is free, forever. Upgrade only when you're ready for the full path.</p>
  </div>
  <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-[22px] items-stretch">
    <!-- free -->
    <div class="bg-surface-tertiary border border-glass-10 rounded-[26px] px-8 py-9 flex flex-col">
      <div class="font-display text-20 font-semibold mb-2">Free</div>
      <div class="flex items-baseline gap-1.5 mb-1.5"><span class="font-display text-46 font-extrabold">0</span><span class="text-16 text-neutral-500">MMK / forever</span></div>
      <p class="text-14-5 text-neutral-500 mb-[26px] leading-150">Everything you need to try La Yaung properly.</p>
      <div class="flex flex-col gap-[13px] mb-[30px]">
        {freePlan.map((x) => (
          <div class="flex gap-[11px] items-start text-15 text-neutral-150"><span class="text-success-text">✓</span><span>{x}</span></div>
        ))}
      </div>
      <a href="#access" class="ly-cta mt-auto text-center font-display font-semibold text-15 text-content-primary bg-glass-7 border border-glass-18 p-3.5 rounded-[14px] transition-transform hover:-translate-y-0.5">Start free</a>
    </div>
    <!-- premium -->
    <div class="bg-premium border-[1.5px] border-border-interactive/45 rounded-[26px] px-8 py-9 flex flex-col relative overflow-hidden">
      <div class="font-mono absolute top-0 right-0 font-bold text-10 tracking-caps text-content-on-brand bg-surface-brand px-4 py-2 rounded-[0_26px_0_14px]">COMING SOON</div>
      <div class="font-display text-20 font-semibold mb-2 text-gold-200">Premium</div>
      <div class="flex items-baseline gap-1.5 mb-1.5"><span class="font-display text-46 font-extrabold">Early-bird</span></div>
      <p class="text-14-5 text-neutral-200 mb-[26px] leading-150">Beta members lock in our lowest price for life.</p>
      <div class="flex flex-col gap-[13px] mb-[30px]">
        {proPlan.map((x) => (
          <div class="flex gap-[11px] items-start text-15 text-content-primary"><span class="text-content-brand">✦</span><span>{x}</span></div>
        ))}
      </div>
      <a href="#access" class="ly-cta mt-auto text-center font-display font-semibold text-15 text-content-on-brand bg-gold p-3.5 rounded-[14px] shadow-[0_12px_28px_-8px_rgba(255,209,94,0.5)] transition-transform hover:-translate-y-0.5">Join the waitlist</a>
    </div>
  </div>
</section>
