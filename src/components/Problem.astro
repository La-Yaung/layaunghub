---
import { problems } from '../data/content';
import Icon from './Icon.astro';
---
<section id="problem" class="ly-reveal max-w-[1280px] mx-auto py-[clamp(70px,9vw,120px)] px-[clamp(20px,5vw,72px)]">
  <div class="max-w-[760px] mb-14">
    <div class="font-mono text-12 tracking-caps-xl uppercase text-content-brand mb-[18px]">01 / The problem</div>
    <h2 class="font-display text-display-md font-bold leading-106">Studying for IGCSE &amp; GED in Myanmar is <span class="italic font-medium text-gold">harder than it should be.</span></h2>
  </div>
  <div class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-[18px]">
    {problems.map((p) => (
      <div class="relative overflow-hidden bg-surface-tertiary border border-border-subtle rounded-[20px] px-[26px] py-7 transition duration-200 hover:-translate-y-1 hover:border-border-interactive/30">
        <div class="w-12 h-12 rounded-[14px] bg-surface-brand/[0.08] border border-border-interactive/[0.22] flex items-center justify-center mb-5"><Icon name={p.icon} size={24} class="text-content-brand" /></div>
        <h3 class="font-display text-19 font-semibold mb-2.5 leading-125">{p.title}</h3>
        <p class="text-15 leading-155 text-content-secondary">{p.body}</p>
      </div>
    ))}
  </div>
  <div class="mt-[42px] flex items-center gap-[18px] flex-wrap bg-banner-gold border border-border-interactive/20 rounded-[18px] px-7 py-[22px]">
    <div class="font-display text-gold text-stat font-extrabold">50k–150k</div>
    <div class="text-15-5 text-content-primary leading-150"><strong class="text-content-primary">MMK per subject, every month.</strong> That's what private tutoring costs — out of reach for most families.</div>
  </div>
</section>
