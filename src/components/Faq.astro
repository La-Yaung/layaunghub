---
import { faqs } from '../data/content';
---
<section id="faq" class="ly-reveal max-w-[880px] mx-auto pt-[clamp(40px,6vw,56px)] px-[clamp(20px,5vw,72px)] pb-[clamp(70px,9vw,110px)]">
  <div class="max-w-[760px] mb-11">
    <div class="font-mono text-12 tracking-caps-xl uppercase text-content-brand mb-[18px]">06 / FAQ</div>
    <h2 class="font-display text-display-md font-bold leading-106">GED &amp; IGCSE, <span class="text-gold">questions answered.</span></h2>
    <p class="text-17 text-content-secondary mt-[18px] leading-160">Everything Myanmar students ask before they start. Still curious? <a href={`mailto:hlaminnaing@layaunghub.com`} class="text-content-brand hover:text-content-brand transition-colors">Email us</a>.</p>
  </div>
  <div class="flex flex-col gap-3">
    {faqs.map((f) => (
      <details class="ly-faq transition duration-200 hover:-translate-y-1 hover:border-border-interactive/30 bg-surface-tertiary border border-border-subtle rounded-[18px] py-[22px] px-[26px]">
        <summary class="flex items-center justify-between gap-4">
          <span class="font-display text-18 font-semibold leading-130 text-content-primary">{f.q}</span>
          <span class="ly-faq-plus flex-none text-content-brand text-24 leading-100 font-light" aria-hidden="true">+</span>
        </summary>
        <p class="text-15-5 leading-165 text-content-secondary mt-3.5">{f.a}</p>
      </details>
    ))}
  </div>
</section>
