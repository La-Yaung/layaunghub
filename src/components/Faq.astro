---
import { faqs } from '../data/content';
---
<section id="faq" class="ly-reveal max-w-[880px] mx-auto pt-[clamp(40px,6vw,56px)] px-[clamp(20px,5vw,72px)] pb-[clamp(70px,9vw,110px)]">
  <div class="max-w-[760px] mb-11">
    <div class="font-mono text-xs tracking-[0.14em] uppercase text-accent mb-[18px]">06 / FAQ</div>
    <h2 class="font-display text-[clamp(30px,4.6vw,52px)] font-bold leading-[1.06]">GED &amp; IGCSE, <span class="text-gold">questions answered.</span></h2>
    <p class="text-[17px] text-muted mt-[18px] leading-[1.6]">Everything Myanmar students ask before they start. Still curious? <a href={`mailto:hlaminnaing@layaunghub.com`} class="text-accent hover:text-accent transition-colors">Email us</a>.</p>
  </div>
  <div class="flex flex-col gap-3">
    {faqs.map((f) => (
      <details class="ly-faq transition duration-200 hover:-translate-y-1 hover:border-accent/30 bg-white/[0.04] border border-white/[0.08] rounded-[18px] py-[22px] px-[26px]">
        <summary class="flex items-center justify-between gap-4">
          <span class="font-display text-[18px] font-semibold leading-[1.3] text-ink">{f.q}</span>
          <span class="ly-faq-plus flex-none text-accent text-2xl leading-none font-light" aria-hidden="true">+</span>
        </summary>
        <p class="text-[15.5px] leading-[1.65] text-muted mt-3.5">{f.a}</p>
      </details>
    ))}
  </div>
</section>
