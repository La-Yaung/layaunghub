---
import { FORMSPREE_ENDPOINT } from '../data/content';
interface Props { dark?: boolean; center?: boolean; }
const { dark = false, center = false } = Astro.props;

const wrap = [
  'ly-waitlist flex flex-wrap gap-2.5 mt-[34px] max-w-[480px]',
  center ? 'justify-center mx-auto' : '',
].join(' ');

const input = [
  'ly-input flex-[1_1_220px] min-w-[200px] text-content-primary text-15-5 px-[18px] py-[15px]',
  'rounded-[14px] outline-none transition-colors',
  dark
    ? 'bg-glass-8 border border-glass-20 focus:border-border-interactive/70'
    : 'bg-glass-6 border border-border-strong focus:border-border-interactive/60 focus:bg-glass-9',
].join(' ');

const button =
  'ly-cta font-display font-semibold text-15 text-content-on-brand bg-gold border-none px-[26px] py-[15px] ' +
  'rounded-[14px] cursor-pointer whitespace-nowrap shadow-[0_10px_26px_-8px_rgba(255,209,94,0.55)] ' +
  'transition-transform hover:-translate-y-0.5';

const fieldId = dark ? 'email-cta' : 'email-hero';
---
<form
  class={wrap}
  action={FORMSPREE_ENDPOINT}
  method="POST"
  data-theme={dark ? 'dark' : 'light'}
  data-endpoint={FORMSPREE_ENDPOINT}
>
  <label class="sr-only" for={fieldId}>Email address</label>
  <input
    id={fieldId}
    class={input}
    type="email"
    name="email"
    required
    autocomplete="email"
    placeholder="Enter your email"
  />
  <!-- Helps you see which CTA converted, inside Formspree submissions -->
  <input type="hidden" name="_source" value={dark ? 'final-cta' : 'hero'} />
  <input type="hidden" name="_subject" value="New La Yaung Hub early-access signup" />
  <button class={button} type="submit">Get Early Access</button>
</form>
