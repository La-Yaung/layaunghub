---
import { FORMSPREE_ENDPOINT } from '../data/content';
import { getContent } from '../data/i18n';

interface Props { dark?: boolean; center?: boolean; }
const { dark = false, center = false } = Astro.props;

const { ui } = getContent(Astro.currentLocale);
const f = ui.form;

const wrap = [
  'ly-waitlist flex flex-wrap gap-2.5 mt-[34px] max-w-[480px]',
  center ? 'justify-center mx-auto' : '',
].join(' ');

const input = [
  'ly-input flex-[1_1_220px] min-w-[200px] text-content-primary placeholder:text-content-tertiary text-15-5 px-[18px] py-[15px]',
  'rounded-[14px] outline-none transition-colors',
  'bg-surface-primary border border-border-strong focus:border-border-interactive/60',
].join(' ');

const button =
  'ly-cta font-display font-semibold text-15 text-content-on-brand bg-gold border-none px-[26px] py-[15px] ' +
  'rounded-[14px] cursor-pointer whitespace-nowrap shadow-[0_10px_26px_-8px_rgba(95,75,241,0.45)] ' +
  'transition-transform hover:-translate-y-0.5';

const fieldId = dark ? 'email-cta' : 'email-hero';
---
<form
  class={wrap}
  action={FORMSPREE_ENDPOINT}
  method="POST"
  data-theme="light"
  data-endpoint={FORMSPREE_ENDPOINT}
  data-success-pre={f.successPre}
  data-success-post={f.successPost}
  data-error-text={f.error}
>
  <label class="sr-only" for={fieldId}>{f.emailLabel}</label>
  <input
    id={fieldId}
    class={input}
    type="email"
    name="email"
    required
    autocomplete="email"
    placeholder={f.placeholder}
  />
  <!-- Helps you see which CTA converted, inside Formspree submissions -->
  <input type="hidden" name="_source" value={dark ? 'final-cta' : 'hero'} />
  <input type="hidden" name="_subject" value="New La Yaung Hub early-access signup" />
  <button class={button} type="submit">{f.button}</button>
</form>
