---
import WaitlistForm from './WaitlistForm.astro';
import Icon from './Icon.astro';
---
<header id="top" class="max-w-[1280px] mx-auto pt-[clamp(36px,6vw,80px)] px-[clamp(20px,5vw,72px)] pb-[clamp(60px,8vw,110px)] flex gap-[clamp(40px,6vw,80px)] items-center flex-wrap">
  <!-- left -->
  <div class="flex-[1_1_440px] min-w-[300px]">
    <div class="inline-flex items-center gap-[9px] bg-accent/10 border border-accent/[0.28] px-3.5 py-[7px] rounded-full mb-7">
      <span class="w-[7px] h-[7px] rounded-full bg-accent shadow-[0_0_10px_#FFD66B]"></span>
      <span class="font-mono text-xs font-normal tracking-[0.06em] text-accent-light">Beta launching 2026</span>
    </div>
    <h1 class="font-display text-[clamp(40px,6.4vw,72px)] font-extrabold leading-none">Watch the lesson.<br>Then <span class="text-gold">actually do it.</span></h1>
    <p class="italic font-medium text-[clamp(19px,2.4vw,26px)] text-ink-soft mt-5 leading-[1.4]">La Yaung · <span class="font-mm">လရောင်</span> — interactive, bilingual learning for Myanmar students.</p>
    <p class="text-[clamp(16px,1.8vw,18px)] text-muted mt-[18px] leading-[1.6] max-w-[520px]">Short video lessons paired with hands-on practice — all mapped to the real IGCSE &amp; GED syllabus, with teacher feedback and a clear map of what to study next.</p>

    <WaitlistForm />
    <div class="text-[13.5px] text-faint mt-3.5 flex items-center gap-2"><span class="text-accent">✦</span> Free to start · First lesson of every topic, on us.</div>
  </div>

  <!-- right: product mockup -->
  <div class="flex-[1_1_380px] min-w-[300px] flex justify-center relative">
    <div class="absolute w-[440px] h-[440px] rounded-full bg-[radial-gradient(circle,rgba(244,206,94,0.26),rgba(244,206,94,0.05)_55%,transparent_72%)] animate-glow z-0"></div>
    <div class="relative z-[1] animate-float">
      <!-- phone -->
      <div class="w-[288px] bg-[linear-gradient(180deg,#0E1640,#0A1030)] border-8 border-deep rounded-[44px] overflow-hidden shadow-[0_44px_90px_-26px_rgba(0,0,0,0.75),0_0_70px_-16px_rgba(244,206,94,0.22)]">
        <div class="pt-7 px-[18px] pb-[22px]">
          <div class="font-display text-[18px] font-bold text-ink mb-3.5">Quadratic Equations</div>
          <div class="flex items-center justify-between text-[11.5px] text-muted-2 mb-[7px]"><span>Lesson 3 of 8</span><span class="text-accent font-semibold">45%</span></div>
          <div class="h-[5px] rounded-[10px] bg-white/10 mb-4 overflow-hidden"><div class="w-[45%] h-full bg-[linear-gradient(90deg,#FFE7A0,#F0A93A)]"></div></div>
          <!-- tabs -->
          <div class="flex gap-1.5 mb-4">
            <span class="flex-1 text-center font-display font-semibold text-[11px] text-bg bg-[linear-gradient(100deg,#FFE7A0,#F0A93A)] py-2 rounded-[10px]">Learn</span>
            <span class="flex-1 text-center font-display font-semibold text-[11px] text-ink-muted bg-white/[0.06] py-2 rounded-[10px]">Practice</span>
            <span class="flex-1 text-center font-display font-semibold text-[11px] text-ink-muted bg-white/[0.06] py-2 rounded-[10px]">Notes</span>
            <span class="flex-1 text-center font-display font-semibold text-[11px] text-ink-muted bg-white/[0.06] py-2 rounded-[10px]">More</span>
          </div>
          <!-- video -->
          <div class="relative h-[140px] rounded-2xl overflow-hidden bg-[radial-gradient(120%_90%_at_30%_20%,#243089,#141C4A_70%)] border border-white/[0.08] mb-3.5">
            <div class="absolute inset-0 opacity-50 bg-[radial-gradient(circle_at_75%_30%,rgba(244,206,94,0.45),transparent_45%)]"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-accent/95 flex items-center justify-center shadow-[0_8px_24px_rgba(244,206,94,0.5)]"><span class="text-bg text-base ml-[3px]">▶</span></div>
            <div class="absolute left-2.5 right-2.5 bottom-[9px] flex items-center gap-[7px]"><span class="text-[9px] text-ink">0:51</span><span class="flex-1 h-[3px] rounded-[10px] bg-white/25"><span class="block w-[34%] h-full rounded-[10px] bg-accent"></span></span><span class="text-[9px] text-ink">2:31</span></div>
          </div>
          <!-- explanation -->
          <div class="bg-white/[0.04] border border-white/[0.08] rounded-[14px] p-[13px]">
            <div class="flex items-center gap-[7px] mb-2"><Icon name="bulb" size={15} class="text-accent-light" /><span class="italic font-medium text-[13px] text-accent-light">Explanation</span></div>
            <div class="text-center font-display font-semibold text-sm text-ink bg-white/5 rounded-[9px] p-[9px]">ax² + bx + c = 0</div>
          </div>
        </div>
      </div>
      <img src="/assets/layaung-logo.png" alt="" aria-hidden="true" width="72" height="72" class="absolute top-[-22px] left-[-30px] w-[72px] h-[72px] rounded-[18px] shadow-[0_16px_32px_-8px_rgba(0,0,0,0.6)] border-2 border-white/10" />
      <div class="absolute bottom-[46px] right-[-34px] bg-panel border border-accent/40 rounded-2xl px-4 py-[13px] shadow-[0_18px_40px_-12px_rgba(0,0,0,0.6)] flex items-center gap-[11px]">
        <div class="w-[34px] h-[34px] rounded-[10px] bg-[linear-gradient(135deg,#FFE7A0,#F0A93A)] flex items-center justify-center"><Icon name="target" size={19} class="text-bg" /></div>
        <div><div class="font-display font-semibold text-[12.5px] text-ink">Practice</div><div class="text-[10.5px] text-muted-2">9 activity types</div></div>
      </div>
    </div>
  </div>
</header>

<!-- logo strip / trust -->
<div class="max-w-[1280px] mx-auto px-[clamp(20px,5vw,72px)] pb-5">
  <div class="flex gap-[clamp(20px,4vw,56px)] flex-wrap justify-center items-center px-7 py-6 bg-white/[0.03] border border-white/[0.07] rounded-[18px]">
    <span class="font-mono text-[11.5px] tracking-[0.12em] uppercase text-faint-3">Built for</span>
    <span class="font-display text-[18px] font-semibold text-[#D6DBF6]">IGCSE · Cambridge</span>
    <span class="w-[5px] h-[5px] rounded-full bg-accent"></span>
    <span class="font-display text-[18px] font-semibold text-[#D6DBF6]">GED</span>
    <span class="w-[5px] h-[5px] rounded-full bg-accent"></span>
    <span class="font-display text-[18px] font-semibold text-[#D6DBF6]">Myanmar Grades 10–12</span>
  </div>
</div>
