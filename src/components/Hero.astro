---
import WaitlistForm from './WaitlistForm.astro';
import Icon from './Icon.astro';
---
<header id="top" class="max-w-[1280px] mx-auto pt-[clamp(36px,6vw,80px)] px-[clamp(20px,5vw,72px)] pb-[clamp(60px,8vw,110px)] flex gap-[clamp(40px,6vw,80px)] items-center flex-wrap">
  <!-- left -->
  <div class="flex-[1_1_440px] min-w-[300px]">
    <div class="inline-flex items-center gap-[9px] bg-surface-brand/10 border border-border-interactive/[0.28] px-3.5 py-[7px] rounded-full mb-7">
      <span class="w-[7px] h-[7px] rounded-full bg-surface-brand shadow-[0_0_10px_#FFD66B]"></span>
      <span class="font-mono text-12 font-normal tracking-looser text-gold-200">Beta launching 2026</span>
    </div>
    <h1 class="font-display text-display-xl font-extrabold leading-100">Watch the lesson.<br>Then <span class="text-gold">actually do it.</span></h1>
    <p class="italic font-medium text-lead text-neutral-200 mt-5 leading-140">La Yaung · <span class="font-mm">လရောင်</span> — interactive, bilingual learning for Myanmar students.</p>
    <p class="text-body text-content-secondary mt-[18px] leading-160 max-w-[520px]">Short video lessons paired with hands-on practice — all mapped to the real IGCSE &amp; GED syllabus, with teacher feedback and a clear map of what to study next.</p>

    <p class="italic font-medium text-15-5 text-neutral-200 mt-6 flex items-center gap-2.5 max-w-[520px]">
      <Icon name="moon" size={18} class="text-content-brand shrink-0" />
      <span><span class="font-mm not-italic">လရောင်</span> means <em class="text-gold not-italic font-semibold">moonlight</em> — because no one should have to study in the dark.</span>
    </p>

    <WaitlistForm />
    <div class="text-13-5 text-content-tertiary mt-3.5 flex items-center gap-2"><span class="text-content-brand">✦</span> Free to start · First lesson of every topic, on us.</div>
  </div>

  <!-- right: product mockup -->
  <div class="flex-[1_1_380px] min-w-[300px] flex justify-center relative">
    <div class="absolute w-[440px] h-[440px] rounded-full bg-glow-hero animate-glow z-0"></div>
    <div class="relative z-[1] animate-float">
      <!-- phone -->
      <div class="w-[288px] bg-phone-a border-8 border-deep rounded-[44px] overflow-hidden shadow-[0_44px_90px_-26px_rgba(0,0,0,0.75),0_0_70px_-16px_rgba(244,206,94,0.22)]">
        <div class="pt-7 px-[18px] pb-[22px]">
          <div class="font-display text-18 font-bold text-content-primary mb-3.5">Quadratic Equations</div>
          <div class="flex items-center justify-between text-11-5 text-neutral-500 mb-[7px]"><span>Lesson 3 of 8</span><span class="text-content-brand font-semibold">45%</span></div>
          <div class="h-[5px] rounded-[10px] bg-glass-10 mb-4 overflow-hidden"><div class="w-[45%] h-full bg-gold-bar"></div></div>
          <!-- tabs -->
          <div class="flex gap-1.5 mb-4">
            <span class="flex-1 text-center font-display font-semibold text-11 text-content-on-brand bg-gold-tab py-2 rounded-[10px]">Learn</span>
            <span class="flex-1 text-center font-display font-semibold text-11 text-neutral-300 bg-glass-6 py-2 rounded-[10px]">Practice</span>
            <span class="flex-1 text-center font-display font-semibold text-11 text-neutral-300 bg-glass-6 py-2 rounded-[10px]">Notes</span>
            <span class="flex-1 text-center font-display font-semibold text-11 text-neutral-300 bg-glass-6 py-2 rounded-[10px]">More</span>
          </div>
          <!-- video -->
          <div class="relative h-[140px] rounded-2xl overflow-hidden bg-screen border border-border-subtle mb-3.5">
            <div class="absolute inset-0 opacity-50 bg-glow-spot"></div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-surface-brand/95 flex items-center justify-center shadow-[0_8px_24px_rgba(244,206,94,0.5)]"><span class="text-content-on-brand text-16 ml-[3px]">▶</span></div>
            <div class="absolute left-2.5 right-2.5 bottom-[9px] flex items-center gap-[7px]"><span class="text-9 text-content-primary">0:51</span><span class="flex-1 h-[3px] rounded-[10px] bg-glass-25"><span class="block w-[34%] h-full rounded-[10px] bg-surface-brand"></span></span><span class="text-9 text-content-primary">2:31</span></div>
          </div>
          <!-- explanation -->
          <div class="bg-surface-tertiary border border-border-subtle rounded-[14px] p-[13px]">
            <div class="flex items-center gap-[7px] mb-2"><Icon name="bulb" size={15} class="text-gold-200" /><span class="italic font-medium text-13 text-gold-200">Explanation</span></div>
            <div class="text-center font-display font-semibold text-14 text-content-primary bg-glass-5 rounded-[9px] p-[9px]">ax² + bx + c = 0</div>
          </div>
        </div>
      </div>
      <img src="/assets/layaung-logo.png" alt="" aria-hidden="true" width="72" height="72" class="absolute top-[-22px] left-[-30px] w-[72px] h-[72px] rounded-[18px] shadow-[0_16px_32px_-8px_rgba(0,0,0,0.6)] border-2 border-glass-10" />
      <div class="absolute bottom-[46px] right-[-34px] bg-surface-secondary border border-border-interactive/40 rounded-2xl px-4 py-[13px] shadow-[0_18px_40px_-12px_rgba(0,0,0,0.6)] flex items-center gap-[11px]">
        <div class="w-[34px] h-[34px] rounded-[10px] bg-gold-tile flex items-center justify-center"><Icon name="target" size={19} class="text-content-on-brand" /></div>
        <div><div class="font-display font-semibold text-12-5 text-content-primary">Practice</div><div class="text-10-5 text-neutral-500">9 activity types</div></div>
      </div>
    </div>
  </div>
</header>

<!-- logo strip / trust -->
<div class="max-w-[1280px] mx-auto px-[clamp(20px,5vw,72px)] pb-5">
  <div class="flex gap-[clamp(20px,4vw,56px)] flex-wrap justify-center items-center px-7 py-6 bg-glass-3 border border-glass-7 rounded-[18px]">
    <span class="font-mono text-11-5 tracking-caps-lg uppercase text-neutral-650">Built for</span>
    <span class="font-display text-18 font-semibold text-neutral-150">IGCSE · Cambridge</span>
    <span class="w-[5px] h-[5px] rounded-full bg-surface-brand"></span>
    <span class="font-display text-18 font-semibold text-neutral-150">GED</span>
    <span class="w-[5px] h-[5px] rounded-full bg-surface-brand"></span>
    <span class="font-display text-18 font-semibold text-neutral-150">Myanmar Grades 10–12</span>
  </div>
</div>
