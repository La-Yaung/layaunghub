---
import { nav } from '../data/content';
---
<nav class="flex items-center justify-between gap-5 py-5 px-[clamp(20px,5vw,72px)] max-w-[1280px] mx-auto">
  <a href="#top" class="flex items-center gap-3" aria-label="La Yaung Hub home">
    <img src="/assets/layaung-logo.png" alt="La Yaung Hub logo" width="46" height="46" class="w-[46px] h-[46px] rounded-[13px] shadow-[0_6px_20px_rgba(0,0,0,0.4)]" />
    <span class="font-display text-[21px] font-bold tracking-[-0.01em]">La Yaung <span class="font-medium opacity-70 text-[15px]">Hub</span></span>
  </a>
  <div class="flex items-center gap-[30px]">
    <div class="flex gap-7 items-center max-[820px]:hidden">
      {nav.map((item) => (
        <a href={item.href} class="text-[15px] font-medium text-neutral-300 hover:text-content-brand transition-colors">{item.label}</a>
      ))}
    </div>
    <a href="#access" class="font-display font-semibold text-[14.5px] text-content-on-brand bg-gold px-5 py-[11px] rounded-full shadow-[0_8px_22px_-6px_rgba(255,209,94,0.5)] transition-transform hover:-translate-y-0.5">Get Early Access</a>
  </div>
</nav>
