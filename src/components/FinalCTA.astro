---
import WaitlistForm from './WaitlistForm.astro';
import { getContent } from '../data/i18n';

const { ui } = getContent(Astro.currentLocale);
const c = ui.cta;
---
<section id="access" class="max-w-[1280px] mx-auto pt-0 px-[clamp(20px,5vw,72px)] pb-[clamp(64px,8vw,100px)]">
  <div class="relative overflow-hidden rounded-[32px] bg-cta-card border border-border-interactive/[0.22] py-[clamp(44px,6vw,80px)] px-[clamp(28px,5vw,72px)] text-center">
    <!-- glowing crescent moon (retired the flat orb) -->
    <div aria-hidden="true" class="absolute top-[-140px] right-[-100px] w-[400px] h-[400px] pointer-events-none animate-float">
      <div class="absolute inset-[-52px] rounded-full bg-glow-moon animate-glow"></div>
      <div class="absolute inset-0 rounded-full bg-moon-crescent mask-crescent moon-aura opacity-[0.92]"></div>
    </div>
    <div class="absolute inset-0 bg-glow-cta pointer-events-none"></div>
    <div class="relative z-[1] max-w-[680px] mx-auto">
      <div class="inline-flex items-center gap-[9px] bg-surface-brand/[0.14] border border-border-interactive/[0.3] px-3.5 py-[7px] rounded-[100px] mb-[26px]">
        <span class="w-[7px] h-[7px] rounded-full bg-surface-brand shadow-[0_0_10px_#7C64F0]"></span>
        <span class="font-mono text-12 font-normal tracking-loose text-content-brand">{c.badge}</span>
      </div>
      <h2 class="font-display text-display-lg font-extrabold leading-104">{c.h2Pre}<span class="text-gold">{c.h2Highlight}</span></h2>
      <p class="text-body-lg text-content-primary mt-5 mx-auto leading-160 max-w-[520px]">{c.body}</p>
      <WaitlistForm dark center />
      <div class="text-13-5 text-content-tertiary mt-4">{c.noSpam}</div>
    </div>
  </div>
</section>
