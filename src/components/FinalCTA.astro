---
import WaitlistForm from './WaitlistForm.astro';
---
<section id="access" class="max-w-[1280px] mx-auto pt-0 px-[clamp(20px,5vw,72px)] pb-[clamp(64px,8vw,100px)]">
  <div class="relative overflow-hidden rounded-[32px] bg-cta-card border border-border-interactive/[0.22] py-[clamp(44px,6vw,80px)] px-[clamp(28px,5vw,72px)] text-center">
    <div class="absolute top-[-90px] right-[-60px] w-[280px] h-[280px] rounded-full bg-moon shadow-[0_0_80px_rgba(244,206,94,0.4)] opacity-[0.85]"></div>
    <div class="absolute inset-0 bg-glow-cta pointer-events-none"></div>
    <div class="relative z-[1] max-w-[680px] mx-auto">
      <div class="inline-flex items-center gap-[9px] bg-surface-brand/[0.14] border border-border-interactive/[0.3] px-3.5 py-[7px] rounded-[100px] mb-[26px]">
        <span class="w-[7px] h-[7px] rounded-full bg-surface-brand shadow-[0_0_10px_#FFD66B]"></span>
        <span class="font-mono text-12 font-normal tracking-loose text-gold-200">Beta launching 2026 · Limited early access</span>
      </div>
      <h2 class="font-display text-display-lg font-extrabold leading-104">Be first under <span class="text-gold">the moonlight.</span></h2>
      <p class="text-body-lg text-neutral-200 mt-5 mx-auto leading-160 max-w-[520px]">Join the waitlist and we'll invite you the moment the beta opens — plus lifetime early-bird pricing.</p>
      <WaitlistForm dark center />
      <div class="text-13-5 text-content-tertiary mt-4">No spam. Just one email when we're ready for you.</div>
    </div>
  </div>
</section>
