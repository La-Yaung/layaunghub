---
// Renders one bilingual informational guide (see src/data/guides.ts) as a full
// page body: Nav → breadcrumb → article (typed blocks incl. tables) → FAQ →
// related guides → waitlist CTA → Footer. Token utilities only, no inline CSS.
import Background from './Background.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import Icon from './Icon.astro';
import WaitlistForm from './WaitlistForm.astro';
import { getContent, getGuides, getQuiz } from '../data/i18n';
import { guideOrder, type GuideSlug } from '../data/guides';

interface Props { slug: GuideSlug; }
const { slug } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const { site, ui } = getContent(locale);
const guides = getGuides(locale);
const guide = guides[slug];

const base = locale === 'my' ? '/my/' : '/';
const otherBase = locale === 'my' ? '/' : '/my/';
const switchHref = `${otherBase}${slug}/`;
const homeLabel = locale === 'my' ? 'ပင်မ' : 'Home';

// The other two guides plus the free quiz — the "keep reading" cross-links.
const quiz = getQuiz(locale);
const related = [
  ...guideOrder
    .filter((s) => s !== slug)
    .map((s) => ({ href: `${base}${s}/`, label: guides[s].navLabel, eyebrow: guides[s].eyebrow, icon: guides[s].icon })),
  { href: `${base}ged-readiness-quiz/`, label: quiz.navLabel, eyebrow: quiz.eyebrow, icon: 'target' as const },
];
---
<div class="relative overflow-hidden bg-app">
  <Background />
  <div class="relative z-[2]">
    <Nav base={base} switchHref={switchHref} />

    <article class="max-w-[820px] mx-auto px-[clamp(20px,5vw,72px)] pt-[clamp(24px,4vw,44px)] pb-[clamp(56px,7vw,88px)]">
      <!-- Breadcrumb (matches the BreadcrumbList JSON-LD) -->
      <nav aria-label="Breadcrumb" class="text-13 text-content-tertiary mb-7 flex items-center gap-2">
        <a href={base} class="hover:text-content-brand transition-colors">{homeLabel}</a>
        <span aria-hidden="true">/</span>
        <span class="text-content-secondary">{guide.eyebrow}</span>
      </nav>

      <!-- Header -->
      <header class="ly-reveal mb-[clamp(28px,4vw,44px)]">
        <div class="inline-flex items-center gap-2 mb-5 rounded-full bg-surface-brand/[0.08] border border-border-interactive/25 px-3.5 py-[7px]">
          <Icon name={guide.icon} size={16} class="text-content-brand" />
          <span class="font-mono text-11-5 tracking-caps uppercase text-content-brand">{guide.eyebrow}</span>
        </div>
        <h1 class="font-display text-display-sm font-bold leading-110 text-content-primary">{guide.h1}</h1>
        <p class="text-19 text-content-secondary mt-5 leading-155">{guide.lead}</p>
        <div class="flex items-center gap-3 mt-6 text-13 text-content-tertiary">
          <span>{guide.updated}</span>
          <span aria-hidden="true" class="w-1 h-1 rounded-full bg-border-strong"></span>
          <span>{guide.readingTime}</span>
        </div>
      </header>

      <!-- Body blocks -->
      <div class="flex flex-col">
        {guide.blocks.map((block) => {
          if (block.type === 'h2') return (
            <h2 class="font-display text-24 font-bold leading-125 text-content-primary mt-[clamp(30px,4vw,44px)] mb-3.5">{block.text}</h2>
          );
          if (block.type === 'h3') return (
            <h3 class="font-display text-19 font-semibold leading-130 text-content-primary mt-7 mb-2.5">{block.text}</h3>
          );
          if (block.type === 'p') return (
            <p class="text-17 leading-165 text-content-secondary mb-4">{block.text}</p>
          );
          if (block.type === 'ul') return (
            <ul class="flex flex-col gap-3 my-2 mb-5">
              {block.items.map((item) => (
                <li class="flex gap-3 text-16-5 leading-160 text-content-secondary">
                  <span class="mt-[9px] flex-none w-1.5 h-1.5 rounded-full bg-surface-brand" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          );
          if (block.type === 'callout') return (
            <div class="my-6 rounded-[18px] bg-card-feature border border-border-interactive/25 p-[clamp(20px,3vw,28px)] flex gap-4">
              {block.icon && <div class="flex-none w-11 h-11 rounded-[13px] bg-icon-soft border border-border-interactive/25 flex items-center justify-center"><Icon name={block.icon} size={22} class="text-content-brand" /></div>}
              <div>
                <div class="font-display text-18 font-semibold text-content-primary leading-130 mb-1.5">{block.title}</div>
                <p class="text-15-5 leading-160 text-content-secondary">{block.text}</p>
              </div>
            </div>
          );
          // table
          return (
            <figure class="my-6">
              <div class="overflow-x-auto rounded-[16px] border border-border-subtle">
                <table class="w-full border-collapse text-left text-15">
                  <thead>
                    <tr class="bg-surface-tertiary">
                      {block.columns.map((col) => (
                        <th scope="col" class="font-display text-13 font-semibold uppercase tracking-caps text-content-tertiary px-4 py-3 border-b border-border-subtle align-bottom">{col}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {block.rows.map((row) => (
                      <tr class="border-b border-border-subtle last:border-b-0">
                        {row.map((cell, ci) => (
                          ci === 0
                            ? <th scope="row" class="font-semibold text-content-primary px-4 py-3.5 align-top leading-140 min-w-[130px]">{cell}</th>
                            : <td class="text-content-secondary px-4 py-3.5 align-top leading-150">{cell}</td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {block.caption && <figcaption class="text-12-5 text-content-tertiary mt-2.5 px-1">{block.caption}</figcaption>}
            </figure>
          );
        })}
      </div>

      <!-- Per-guide FAQ (feeds this page's FAQPage JSON-LD) -->
      <section class="ly-reveal mt-[clamp(40px,6vw,64px)]">
        <h2 class="font-display text-24 font-bold leading-120 text-content-primary mb-6">{guide.faqHeading}</h2>
        <div class="flex flex-col gap-3">
          {guide.faqs.map((f) => (
            <details class="ly-faq transition duration-200 hover:-translate-y-1 hover:border-border-interactive/30 bg-surface-tertiary border border-border-subtle rounded-[18px] py-[22px] px-[26px]">
              <summary class="flex items-center justify-between gap-4">
                <span class="font-display text-17 font-semibold leading-130 text-content-primary">{f.q}</span>
                <span class="ly-faq-plus flex-none text-content-brand text-24 leading-100 font-light" aria-hidden="true">+</span>
              </summary>
              <p class="text-15-5 leading-165 text-content-secondary mt-3.5">{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Related guides -->
      <section class="ly-reveal mt-[clamp(40px,6vw,64px)]">
        <h2 class="font-display text-18 font-semibold text-content-primary mb-4">{guide.relatedHeading}</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {related.map((r) => (
            <a href={r.href} class="group flex items-center gap-3.5 rounded-[16px] bg-surface-tertiary border border-border-subtle p-4 transition duration-200 hover:-translate-y-1 hover:border-border-interactive/40">
              <div class="flex-none w-10 h-10 rounded-[12px] bg-icon-soft border border-border-interactive/20 flex items-center justify-center"><Icon name={r.icon} size={19} class="text-content-brand" /></div>
              <div>
                <div class="font-mono text-10-5 tracking-caps uppercase text-content-tertiary">{r.eyebrow}</div>
                <div class="font-display text-15 font-semibold text-content-primary leading-130 group-hover:text-content-brand transition-colors">{r.label}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    </article>

    <!-- Waitlist CTA -->
    <section id="access" class="ly-reveal max-w-[820px] mx-auto px-[clamp(20px,5vw,72px)] pb-[clamp(64px,8vw,100px)]">
      <div class="rounded-[24px] bg-cta-card border border-border-interactive/25 p-[clamp(28px,4vw,48px)] text-center">
        <h2 class="font-display text-display-sm font-bold leading-110 text-content-primary">{guide.cta.title}</h2>
        <p class="text-16-5 text-content-secondary mt-4 leading-160 max-w-[520px] mx-auto">{guide.cta.body}</p>
        <WaitlistForm center={true} />
        <p class="text-13 text-content-tertiary mt-4">{ui.cta.noSpam}</p>
      </div>
    </section>

    <Footer base={base} />
  </div>
</div>
