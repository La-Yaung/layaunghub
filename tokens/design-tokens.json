{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "La Yaung Hub design tokens — W3C DTCG format. Tier 1 = primitives (raw palette/scale). Tier 2 = semantic aliases that reference primitives and switch between light & dark. Brand: bilingual GED/IGCSE EdTech for Myanmar students, mirroring the app's Figma design system. Tone: calm, focused, monochrome purple on a cool-light ground. Target: WCAG 2.1 AA.",

  "color": {
    "$type": "color",

    "primary": {
      "$description": "Brand primary — purple #5F4BF1 (from the app design system).",
      "50":  { "$value": "#EFEBFE" },
      "100": { "$value": "#DED7FC" },
      "200": { "$value": "#C3B7F9" },
      "300": { "$value": "#A08FF4" },
      "400": { "$value": "#7C64F0" },
      "500": { "$value": "#5F4BF1" },
      "600": { "$value": "#4B38C4" },
      "700": { "$value": "#3B2C9B" },
      "800": { "$value": "#2C2172" },
      "900": { "$value": "#1E164E" }
    },

    "ink": {
      "$description": "Cool text inks (design-system values).",
      "base": { "$value": "#130F26" },
      "2":    { "$value": "#3A3646" },
      "3":    { "$value": "#727272" },
      "4":    { "$value": "#9A95A6" }
    },

    "cloud": {
      "$description": "Cool light surfaces & hairlines.",
      "base":   { "$value": "#F8F9FC" },
      "2":      { "$value": "#F1F0F7" },
      "line":   { "$value": "#ECEAF4" },
      "line-2": { "$value": "#DEDBEC" }
    },

    "gold": {
      "$description": "Retired — kept as a primitive only; brand is now monochrome purple and gold is off-page.",
      "50":  { "$value": "#FFF9E8" },
      "100": { "$value": "#FFEFC2" },
      "200": { "$value": "#FFE7A0" },
      "300": { "$value": "#FFDC85" },
      "400": { "$value": "#FFD66B" },
      "500": { "$value": "#FFD15E" },
      "600": { "$value": "#F0A93A" },
      "700": { "$value": "#CC861F" },
      "800": { "$value": "#9C6618" },
      "900": { "$value": "#6E460F" }
    },

    "indigo": {
      "$description": "Legacy secondary — night sky (unused).",
      "50":  { "$value": "#EDEFFB" },
      "100": { "$value": "#D6DBF6" },
      "200": { "$value": "#B9C0E6" },
      "300": { "$value": "#8E96C9" },
      "400": { "$value": "#5C66A8" },
      "500": { "$value": "#3A4488" },
      "600": { "$value": "#2A3796" },
      "700": { "$value": "#20296E" },
      "800": { "$value": "#131A4A" },
      "900": { "$value": "#0A1030" }
    },

    "neutral": {
      "$description": "Blue-tinted grays (still used by the dark Footer panel).",
      "0":   { "$value": "#FFFFFF" },
      "50":  { "$value": "#EDF0FF" },
      "100": { "$value": "#DCE2FB" },
      "200": { "$value": "#C7CEF2" },
      "300": { "$value": "#B9C0E6" },
      "400": { "$value": "#A4ACD6" },
      "500": { "$value": "#9AA3CE" },
      "600": { "$value": "#8089B6" },
      "700": { "$value": "#6E77A4" },
      "800": { "$value": "#3A4470" },
      "900": { "$value": "#131A4A" },
      "950": { "$value": "#0A1030" }
    },

    "green": {
      "$description": "Correct #26CC4B (app value).",
      "50":  { "$value": "#E7F9EF" },
      "100": { "$value": "#C6F0D8" },
      "400": { "$value": "#3AD17A" },
      "500": { "$value": "#26CC4B" },
      "600": { "$value": "#1FA83E" },
      "700": { "$value": "#167A2E" }
    },

    "amber": {
      "$description": "Warning.",
      "50":  { "$value": "#FFF6E5" },
      "100": { "$value": "#FFE8BF" },
      "400": { "$value": "#FFB020" },
      "500": { "$value": "#F59E0B" },
      "600": { "$value": "#D98309" },
      "700": { "$value": "#B26707" }
    },

    "red": {
      "$description": "Wrong / danger #F75455 (app value).",
      "50":  { "$value": "#FEECEC" },
      "100": { "$value": "#FBD0D0" },
      "400": { "$value": "#F87171" },
      "500": { "$value": "#F75455" },
      "600": { "$value": "#E23B3C" },
      "700": { "$value": "#B91C1C" }
    },

    "blue": {
      "$description": "Info.",
      "50":  { "$value": "#E8F1FE" },
      "100": { "$value": "#C9DDFB" },
      "400": { "$value": "#5B9BF8" },
      "500": { "$value": "#3B82F6" },
      "600": { "$value": "#2563EB" },
      "700": { "$value": "#1D4ED8" }
    }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "8pt grid (with 2/4px half-steps).",
    "none": { "$value": "0px" },
    "3xs":  { "$value": "2px" },
    "2xs":  { "$value": "4px" },
    "xs":   { "$value": "8px" },
    "sm":   { "$value": "12px" },
    "md":   { "$value": "16px" },
    "lg":   { "$value": "24px" },
    "xl":   { "$value": "32px" },
    "2xl":  { "$value": "48px" },
    "3xl":  { "$value": "64px" },
    "4xl":  { "$value": "96px" }
  },

  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "xs":   { "$value": "6px" },
    "sm":   { "$value": "10px" },
    "md":   { "$value": "14px" },
    "lg":   { "$value": "20px" },
    "xl":   { "$value": "26px" },
    "2xl":  { "$value": "32px" },
    "full": { "$value": "9999px" }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": ["Poppins", "system-ui", "sans-serif"] },
      "sans":    { "$value": ["Poppins", "system-ui", "sans-serif"] },
      "mono":    { "$value": ["Space Mono", "monospace"] },
      "myanmar": { "$value": ["Noto Sans Myanmar", "sans-serif"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":   { "$value": 400 },
      "medium":    { "$value": 500 },
      "semibold":  { "$value": 600 },
      "bold":      { "$value": 700 },
      "extrabold": { "$value": 800 }
    },
    "size": {
      "$type": "dimension",
      "xs":   { "$value": "12px" },
      "sm":   { "$value": "14px" },
      "base": { "$value": "16px" },
      "md":   { "$value": "18px" },
      "lg":   { "$value": "20px" },
      "xl":   { "$value": "24px" },
      "2xl":  { "$value": "30px" },
      "3xl":  { "$value": "38px" },
      "4xl":  { "$value": "48px" },
      "5xl":  { "$value": "60px" },
      "6xl":  { "$value": "72px" }
    },
    "line-height": {
      "$type": "number",
      "none":    { "$value": 1.0 },
      "tight":   { "$value": 1.12 },
      "snug":    { "$value": 1.3 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.6 },
      "loose":   { "$value": 1.7 }
    },
    "letter-spacing": {
      "$type": "dimension",
      "tighter": { "$value": "-0.02em" },
      "tight":   { "$value": "-0.01em" },
      "normal":  { "$value": "0em" },
      "wide":    { "$value": "0.06em" },
      "wider":   { "$value": "0.14em" }
    }
  },

  "semantic": {
    "$description": "Tier-2 aliases. Reference primitives via {color.x.y}. Light drives the whole page; dark now only skins the Footer panel.",

    "light": {
      "$type": "color",
      "surface": {
        "primary":   { "$value": "{color.neutral.0}",   "$description": "White cards" },
        "secondary": { "$value": "{color.cloud.base}",  "$description": "#F8F9FC app ground / sections" },
        "tertiary":  { "$value": "{color.cloud.2}",     "$description": "Insets, hover fills" },
        "brand":     { "$value": "{color.primary.500}", "$description": "Brand fills (primary buttons)" },
        "inverse":   { "$value": "{color.ink.base}",    "$description": "Inverted blocks" },
        "danger":    { "$value": "{color.red.50}",      "$description": "Destructive surfaces" }
      },
      "content": {
        "primary":   { "$value": "{color.ink.base}", "$description": "Headings & body (#130F26)" },
        "secondary": { "$value": "{color.ink.2}",    "$description": "Muted / supporting text" },
        "tertiary":  { "$value": "{color.ink.3}",    "$description": "Fine print, placeholders" },
        "inverse":   { "$value": "{color.neutral.0}",   "$description": "Text on inverse surfaces" },
        "brand":     { "$value": "{color.primary.600}", "$description": "Brand-colored text (AA on white)" },
        "on-brand":  { "$value": "{color.neutral.0}",   "$description": "White text/icon on purple fills" }
      },
      "border": {
        "subtle":      { "$value": "{color.cloud.line}",   "$description": "Hairlines, dividers" },
        "strong":      { "$value": "{color.cloud.line-2}", "$description": "Input borders, emphasis" },
        "interactive": { "$value": "{color.primary.500}",  "$description": "Focus / active edges" }
      },
      "feedback": {
        "success": {
          "text":   { "$value": "{color.green.700}" },
          "bg":     { "$value": "{color.green.50}" },
          "border": { "$value": "{color.green.100}" }
        },
        "warning": {
          "text":   { "$value": "{color.amber.700}" },
          "bg":     { "$value": "{color.amber.50}" },
          "border": { "$value": "{color.amber.100}" }
        },
        "error": {
          "text":   { "$value": "{color.red.600}" },
          "bg":     { "$value": "{color.red.50}" },
          "border": { "$value": "{color.red.100}" }
        },
        "info": {
          "text":   { "$value": "{color.blue.700}" },
          "bg":     { "$value": "{color.blue.50}" },
          "border": { "$value": "{color.blue.100}" }
        }
      }
    },

    "dark": {
      "$type": "color",
      "surface": {
        "primary":   { "$value": "#17122E",             "$description": "Deep purple-ink Footer panel" },
        "secondary": { "$value": "#221B45",             "$description": "Cards / raised panels" },
        "tertiary":  { "$value": "rgba(255,255,255,0.04)", "$description": "Glass insets, hover fills" },
        "brand":     { "$value": "{color.primary.500}", "$description": "Brand fills" },
        "inverse":   { "$value": "{color.neutral.50}",  "$description": "Inverted blocks on dark" },
        "danger":    { "$value": "rgba(247,84,85,0.12)", "$description": "Destructive surfaces" }
      },
      "content": {
        "primary":   { "$value": "#F4F2FF",             "$description": "Headings & body" },
        "secondary": { "$value": "#B7B0D8",             "$description": "Muted / supporting text" },
        "tertiary":  { "$value": "#8981AE",             "$description": "Fine print, placeholders" },
        "inverse":   { "$value": "{color.ink.base}",    "$description": "Text on inverse/brand surfaces" },
        "brand":     { "$value": "{color.primary.300}", "$description": "Brand-colored text (bright purple on dark)" },
        "on-brand":  { "$value": "{color.neutral.0}",   "$description": "White text/icon on purple fills" }
      },
      "border": {
        "subtle":      { "$value": "rgba(255,255,255,0.08)", "$description": "Hairlines, dividers" },
        "strong":      { "$value": "rgba(255,255,255,0.16)", "$description": "Input borders, emphasis" },
        "interactive": { "$value": "{color.primary.400}",    "$description": "Focus / active edges" }
      },
      "feedback": {
        "success": {
          "text":   { "$value": "{color.green.400}" },
          "bg":     { "$value": "rgba(58,209,122,0.12)" },
          "border": { "$value": "rgba(58,209,122,0.35)" }
        },
        "warning": {
          "text":   { "$value": "{color.amber.400}" },
          "bg":     { "$value": "rgba(255,176,32,0.12)" },
          "border": { "$value": "rgba(255,176,32,0.35)" }
        },
        "error": {
          "text":   { "$value": "{color.red.400}" },
          "bg":     { "$value": "rgba(247,84,85,0.12)" },
          "border": { "$value": "rgba(247,84,85,0.35)" }
        },
        "info": {
          "text":   { "$value": "{color.blue.400}" },
          "bg":     { "$value": "rgba(91,155,248,0.12)" },
          "border": { "$value": "rgba(91,155,248,0.35)" }
        }
      }
    }
  }
}
